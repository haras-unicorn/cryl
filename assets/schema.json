{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Specification",
  "description": "Complete specification for secret generation pipeline.\nContains imports, generations, and exports to execute in order.",
  "type": "object",
  "properties": {
    "exports": {
      "description": "Export operations to run after generation (if not dry-run).",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Export"
      }
    },
    "generations": {
      "description": "Secret generation operations.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Generation"
      }
    },
    "imports": {
      "description": "Import operations to run before generation.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Import"
      }
    }
  },
  "required": [
    "imports",
    "generations",
    "exports"
  ],
  "$defs": {
    "AgeKeyArgs": {
      "description": "Arguments for Age encryption keypair generation.",
      "type": "object",
      "properties": {
        "private": {
          "description": "Path to save the private key.",
          "type": "string"
        },
        "public": {
          "description": "Path to save the public key.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite both key files if they exist.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "public",
        "private"
      ]
    },
    "CockroachCaArgs": {
      "description": "Arguments for CockroachDB CA certificate generation.",
      "type": "object",
      "properties": {
        "private": {
          "description": "Path to save the CA private key.",
          "type": "string"
        },
        "public": {
          "description": "Path to save the CA certificate.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite both CA files.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "public",
        "private"
      ]
    },
    "CockroachClientCertArgs": {
      "description": "Arguments for CockroachDB client certificate generation.",
      "type": "object",
      "properties": {
        "ca_private": {
          "description": "Path to the CockroachDB CA private key.",
          "type": "string"
        },
        "ca_public": {
          "description": "Path to the CockroachDB CA certificate.",
          "type": "string"
        },
        "private": {
          "description": "Path to save the client private key.",
          "type": "string"
        },
        "public": {
          "description": "Path to save the client certificate.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite both certificate and key files.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "user": {
          "description": "CockroachDB username for the client certificate.",
          "type": "string"
        }
      },
      "required": [
        "ca_public",
        "ca_private",
        "user",
        "public",
        "private"
      ]
    },
    "CockroachNodeCertArgs": {
      "description": "Arguments for CockroachDB node certificate generation.",
      "type": "object",
      "properties": {
        "ca_private": {
          "description": "Path to the CockroachDB CA private key.",
          "type": "string"
        },
        "ca_public": {
          "description": "Path to the CockroachDB CA certificate.",
          "type": "string"
        },
        "hosts": {
          "description": "Comma‑separated hostnames/IPs for Subject Alternative Names.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "private": {
          "description": "Path to save the node private key.",
          "type": "string"
        },
        "public": {
          "description": "Path to save the node certificate.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite both certificate and key files.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "ca_public",
        "ca_private",
        "hosts",
        "public",
        "private"
      ]
    },
    "CopyExportArgs": {
      "description": "Arguments for file‑copy export.",
      "type": "object",
      "properties": {
        "from": {
          "description": "Source file path.",
          "type": "string"
        },
        "to": {
          "description": "Destination file path.",
          "type": "string"
        }
      },
      "required": [
        "from",
        "to"
      ]
    },
    "CopyGenArgs": {
      "description": "Arguments for file‑copy generation.",
      "type": "object",
      "properties": {
        "from": {
          "description": "Source file path.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite destination if it already exists.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "to": {
          "description": "Destination file path.",
          "type": "string"
        }
      },
      "required": [
        "from",
        "to"
      ]
    },
    "CopyImportArgs": {
      "description": "Arguments for file‑copy import.",
      "type": "object",
      "properties": {
        "allow_fail": {
          "description": "If true, missing source does not cause failure.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "from": {
          "description": "Source file path.",
          "type": "string"
        },
        "to": {
          "description": "Destination file path.",
          "type": "string"
        }
      },
      "required": [
        "from",
        "to"
      ]
    },
    "DataGenArgs": {
      "description": "Arguments for structured‑data generation (JSON/YAML/TOML).",
      "type": "object",
      "properties": {
        "name": {
          "description": "Destination file name.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite destination if it already exists.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "value": {
          "description": "Structured data to serialize."
        }
      },
      "required": [
        "name",
        "value"
      ]
    },
    "DhparamArgs": {
      "description": "Arguments for OpenSSL DH parameters generation.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Path to save the DH parameters file.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite destination if it exists.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ]
    },
    "EnvArgs": {
      "description": "Arguments for environment (.env) file generation.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Destination file path.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite destination if it exists.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "variables": {
          "description": "Key‑value pairs; values can be strings or file paths.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "variables"
      ]
    },
    "Export": {
      "description": "Export operation - pushes generated secrets to external systems.",
      "oneOf": [
        {
          "description": "Export all files in current directory to Vault KV path.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/VaultExportArgs"
            },
            "exporter": {
              "type": "string",
              "const": "vault"
            }
          },
          "required": [
            "exporter",
            "arguments"
          ]
        },
        {
          "description": "Export a single file to Vault KV path.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/VaultFileExportArgs"
            },
            "exporter": {
              "type": "string",
              "const": "vault-file"
            }
          },
          "required": [
            "exporter",
            "arguments"
          ]
        },
        {
          "description": "Copy file to local filesystem.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/CopyExportArgs"
            },
            "exporter": {
              "type": "string",
              "const": "copy"
            }
          },
          "required": [
            "exporter",
            "arguments"
          ]
        }
      ]
    },
    "Generation": {
      "description": "Secret generation operation.",
      "oneOf": [
        {
          "description": "Copy file during generation phase.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/CopyGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "copy"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Write text file with literal content.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/TextGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "text"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate JSON file from structured data.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/DataGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "json"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate YAML file from structured data.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/DataGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "yaml"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate TOML file from structured data.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/DataGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "toml"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate random alphanumeric identifier.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/IdGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "id"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate random alphanumeric key.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/IdGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "key"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Split a key into Shamir secret shares.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/KeySplitArgs"
            },
            "generator": {
              "type": "string",
              "const": "key-split"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Combine Shamir shares back into a key.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/KeyCombineArgs"
            },
            "generator": {
              "type": "string",
              "const": "key-combine"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate numeric PIN.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/PinGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "pin"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate password with Argon2 hash.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/PasswordGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "password"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate password with yescrypt hash.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/PasswordGenArgs"
            },
            "generator": {
              "type": "string",
              "const": "password-crypt-3"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate age encryption keypair.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/AgeKeyArgs"
            },
            "generator": {
              "type": "string",
              "const": "age-key"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate SSH keypair (ed25519).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/SshKeyArgs"
            },
            "generator": {
              "type": "string",
              "const": "ssh-key"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate WireGuard keypair.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/WireguardKeyArgs"
            },
            "generator": {
              "type": "string",
              "const": "wireguard-key"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate TLS Root CA certificate (EC P‑256).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/TlsRootArgs"
            },
            "generator": {
              "type": "string",
              "const": "tls-root"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate TLS Intermediate CA certificate (EC P‑256).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/TlsIntermediaryArgs"
            },
            "generator": {
              "type": "string",
              "const": "tls-intermediary"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate TLS leaf certificate (EC P‑256).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/TlsLeafArgs"
            },
            "generator": {
              "type": "string",
              "const": "tls-leaf"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate TLS Root CA certificate (RSA 4096).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/TlsRootArgs"
            },
            "generator": {
              "type": "string",
              "const": "tls-rsa-root"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate TLS Intermediate CA certificate (RSA 4096).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/TlsIntermediaryArgs"
            },
            "generator": {
              "type": "string",
              "const": "tls-rsa-intermediary"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate TLS leaf certificate (RSA 4096).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/TlsLeafArgs"
            },
            "generator": {
              "type": "string",
              "const": "tls-rsa-leaf"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate OpenSSL DH parameters (2048‑bit).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/DhparamArgs"
            },
            "generator": {
              "type": "string",
              "const": "tls-dhparam"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate Nebula CA certificate.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/NebulaCaArgs"
            },
            "generator": {
              "type": "string",
              "const": "nebula-ca"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate Nebula node certificate.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/NebulaCertArgs"
            },
            "generator": {
              "type": "string",
              "const": "nebula-cert"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate CockroachDB CA certificate.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/CockroachCaArgs"
            },
            "generator": {
              "type": "string",
              "const": "cockroach-ca"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate CockroachDB node certificate.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/CockroachNodeCertArgs"
            },
            "generator": {
              "type": "string",
              "const": "cockroach-node-cert"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate CockroachDB client certificate.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/CockroachClientCertArgs"
            },
            "generator": {
              "type": "string",
              "const": "cockroach-client-cert"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate environment (.env) file from key‑value pairs.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/EnvArgs"
            },
            "generator": {
              "type": "string",
              "const": "env"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate file from Mustache template.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/MoustacheArgs"
            },
            "generator": {
              "type": "string",
              "const": "moustache"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate and execute Nushell script (requires --allow-script).",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/ScriptArgs"
            },
            "generator": {
              "type": "string",
              "const": "script"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        },
        {
          "description": "Generate SOPS‑encrypted YAML with Age recipients.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/SopsArgs"
            },
            "generator": {
              "type": "string",
              "const": "sops"
            }
          },
          "required": [
            "generator",
            "arguments"
          ]
        }
      ]
    },
    "IdGenArgs": {
      "description": "Arguments for random identifier/key generation.",
      "type": "object",
      "properties": {
        "length": {
          "description": "Length of alphanumeric string (default: id=16, key=32).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "name": {
          "description": "Destination file name.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite destination if it already exists.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ]
    },
    "Import": {
      "description": "Import operation - brings existing data into the working directory.",
      "oneOf": [
        {
          "description": "Import all files from a Vault KV path.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/VaultImportArgs"
            },
            "importer": {
              "type": "string",
              "const": "vault"
            }
          },
          "required": [
            "importer",
            "arguments"
          ]
        },
        {
          "description": "Import a single file from a Vault KV path.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/VaultFileImportArgs"
            },
            "importer": {
              "type": "string",
              "const": "vault-file"
            }
          },
          "required": [
            "importer",
            "arguments"
          ]
        },
        {
          "description": "Copy a file from local filesystem.",
          "type": "object",
          "properties": {
            "arguments": {
              "$ref": "#/$defs/CopyImportArgs"
            },
            "importer": {
              "type": "string",
              "const": "copy"
            }
          },
          "required": [
            "importer",
            "arguments"
          ]
        }
      ]
    },
    "KeyCombineArgs": {
      "description": "Arguments for Shamir secret‑sharing combine.",
      "type": "object",
      "properties": {
        "key": {
          "description": "Path to save reconstructed key.",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite destination if it already exists.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "shares": {
          "description": "List of share file paths to combine.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "threshold": {
          "description": "Required shares (must match original split threshold).",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "key",
        "shares",
        "threshold"
      ]
    },
    "KeySplitArgs": {
      "description": "Arguments for Shamir secret‑sharing split.",
      "type": "object",
      "properties": {
        "key": {
          "description": "Path to source key file (raw content).",
          "type": "string"
        },
        "prefix": {
          "description": "Filename prefix for each share (e.g., \"share‑0\", \"share‑1\").",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite existing share files.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "shares": {
          "description": "Total number of shares to generate.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "threshold": {
          "description": "Minimum shares required to reconstruct.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "key",
        "prefix",
        "shares",
        "threshold"
      ]
    },
    "MoustacheArgs": {
      "description": "Arguments for Mustache template generation.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Base name for output files (‑variables, ‑template suffixes added).",
          "type": "string"
        },
        "renew": {
          "description": "Overwrite output file if it exists.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "template": {
          "description": "Mustache template content.",
